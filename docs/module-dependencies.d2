    stroke: "#01579b"
  }
}

# Main orchestrates everything
main -> cli: parse arguments
main -> board: collect snapshot
main -> stitching: process edges
main -> ui: launch app
main -> catalog: init catalogs

# Module dependencies
cli -> clap_crate: parse args

board -> kicad_ipc: query PCB data
board -> user_path: get user paths

stitching -> clipper2: polygon operations

catalog -> serde_yaml: load YAML
catalog -> jsonschema: validate schema
catalog -> user_path: get user directory

config -> serde_yaml: load/save YAML
config -> serde_json: load/save JSON
config -> jsonschema: validate schemas
config -> user_path: get user directory

ui -> dioxus: render interface
ui -> config: load configuration
ui -> user_path: get app directories

rhai_parser -> rhai: parse/execute scripts

user_path -> units: convert paths (if needed)

# Shared dependencies
units -> serde_json: serialization (optional)

# All modules implicitly depend on user_path for directory management
catalog -> user_path: access app data
config -> user_path: access settings
board -> user_path: access cache

style: {
  stroke-width: 2
  font-size: 11
  padding: 15
}
