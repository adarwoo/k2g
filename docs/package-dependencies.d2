# K2G Package/Library Dependency Diagram

direction: right

# External dependencies cluster
ext: {
  label: External Crates

  serde: Serde
  tokio: Tokio
  dioxus: Dioxus
  clap: Clap
  rhai: Rhai
  thiserror: Thiserror
  serde_json: Serde JSON
  serde_yaml: Serde YAML
  jsonschema: JSON Schema
  log: Log
  image: Image
  rfd: RFD
  clipper2: Clipper2-rust
  nng: NNG
  prost: Prost
  prost_types: Prost Types
  tracing: Tracing
}

# Internal Rust crates cluster
rust: {
  label: Rust Crates

  kicad_ipc_rs: kicad-ipc-rs {
    label: kicad-ipc-rs (v0.4.0)
    description: KiCad IPC API Client
  }

  k2g: K2G (Main) {
    label: k2g (v0.1.0)
    description: GCode Generator
  }
}

# Internal modules cluster (part of k2g)
modules: {
  label: K2G Internal Modules

  main: Main Entry
  cli: CLI Module
  board: Board Module
  catalog: Catalog Module
  config: Config Module
  stitching: Stitching Module
  ui_mod: UI Module
  rhai_parser: Rhai Parser
  units: Units Module
  user_path: User Path Module
}

# Frontend cluster
frontend: {
  label: Frontend

  dioxus_ui: Dioxus Desktop UI

  nextjs: {
    label: kicad-gcode-plugin
    description: Next.js + React

    next: Next.js
    react: React
    react_dom: React DOM
    tailwind: Tailwind CSS
    shadcn: Shadcn UI
    base_ui: Base UI
    lucide: Lucide React
    analytics: Vercel Analytics
  }
}

# Dependencies from k2g to external crates
k2g -> serde: uses
k2g -> tokio: uses async runtime
k2g -> dioxus: desktop UI
k2g -> clap: CLI parsing
k2g -> rhai: scripting
k2g -> thiserror: error handling
k2g -> serde_json: JSON config
k2g -> serde_yaml: YAML config
k2g -> jsonschema: schema validation
k2g -> log: logging
k2g -> image: image processing
k2g -> rfd: file dialogs
k2g -> clipper2: geometry operations

# Dependencies from kicad-ipc-rs to external crates
kicad_ipc_rs -> nng: IPC transport
kicad_ipc_rs -> prost: protobuf
kicad_ipc_rs -> prost_types: protobuf types
kicad_ipc_rs -> thiserror: error handling
kicad_ipc_rs -> tokio: async runtime
kicad_ipc_rs -> tracing: tracing (optional)

# k2g depends on kicad-ipc-rs
k2g -> kicad_ipc_rs: uses (blocking feature)

# Internal module dependencies
main -> cli: parses
main -> board: collects
main -> stitching: processes
main -> ui_mod: launches
main -> catalog: initializes

cli -> clap: uses

board -> kicad_ipc_rs: queries PCB data
board -> user_path: gets paths

catalog -> serde_yaml: loads YAML
catalog -> jsonschema: validates
catalog -> user_path: gets user dir

config -> serde_yaml: loads/saves
config -> serde_json: loads/saves
config -> jsonschema: validates
config -> user_path: gets user dir

stitching -> clipper2: polygon operations

ui_mod -> dioxus: renders UI
ui_mod -> config: loads config
ui_mod -> user_path: gets app dirs

rhai_parser -> rhai: parses scripts

units -> serde: serializes

k2g -> main: contains
k2g -> cli: contains
k2g -> board: contains
k2g -> catalog: contains
k2g -> config: contains
k2g -> stitching: contains
k2g -> ui_mod: contains
k2g -> rhai_parser: contains
k2g -> units: contains
k2g -> user_path: contains

# Frontend connections
k2g -> dioxus_ui: provides data
dioxus_ui -> dioxus: uses framework

nextjs -> next: framework
nextjs -> react: UI library
nextjs -> react_dom: rendering
nextjs -> tailwind: styling
nextjs -> shadcn: components
nextjs -> base_ui: components
nextjs -> lucide: icons
nextjs -> analytics: tracking

style: {
  stroke-width: 2
  font-size: 11
}

ext.style: {
  fill: "#e1f5ff"
  stroke: "#01579b"
}

rust.style: {
  fill: "#fce4ec"
  stroke: "#880e4f"
}

modules.style: {
  fill: "#f3e5f5"
  stroke: "#4a148c"
}

frontend.style: {
  fill: "#e8f5e9"
  stroke: "#1b5e20"
}

kicad_ipc_rs.style: {
  fill: "#fff3e0"
  stroke: "#e65100"
}

k2g.style: {
  fill: "#fce4ec"
  stroke: "#c2185b"
}
