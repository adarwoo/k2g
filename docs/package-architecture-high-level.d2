# K2G Package Architecture - High Level

direction: right

k2g: K2G {
  label: K2G (Main App)
}

kicad_ipc: kicad-ipc-rs {
  label: kicad-ipc-rs
  description: KiCad IPC API Client
}

# External dependency groups
async_rt: {
  label: Async Runtime
  tokio: Tokio
}

serialization: {
  label: Serialization
  serde: Serde
  serde_json: Serde JSON
  serde_yaml: Serde YAML
  prost: Prost (Protobuf)
}

validation: {
  label: Validation & Schema
  jsonschema: JSON Schema
  thiserror: Error Handling
}

ui_fw: {
  label: UI Frameworks
  dioxus: Dioxus (Desktop)
  nextjs: Next.js (Web)
}

scripting: {
  label: Scripting & Processing
  rhai: Rhai
  clipper2: Clipper2
  image: Image
}

tools: {
  label: Tools & Utils
  clap: Clap (CLI)
  log: Log
  rfd: RFD (File Dialog)
  nng: NNG (IPC)
}

# K2G internal modules
k2g_modules: {
  label: K2G Modules

  cli: CLI
  board: Board
  catalog: Catalog
  config: Config
  stitching: Stitching
  ui: UI
  parser: Rhai Parser
}

# Frontend apps
frontend: {
  label: Frontend Applications

  dioxus_app: Dioxus Desktop App
  nextjs_app: Next.js Web Plugin
}

# Main dependencies
k2g -> kicad_ipc: uses (blocking)
k2g -> async_rt: uses
k2g -> serialization: uses
k2g -> validation: uses
k2g -> ui_fw: uses
k2g -> scripting: uses
k2g -> tools: uses
k2g -> k2g_modules: contains

kicad_ipc -> async_rt: uses
kicad_ipc -> serialization: uses
kicad_ipc -> validation: uses
kicad_ipc -> tools: uses

k2g_modules -> kicad_ipc: queries PCB
k2g_modules -> serialization: config I/O
k2g_modules -> validation: schema check
k2g_modules -> scripting: processing
k2g_modules -> ui_fw: rendering

frontend -> k2g: provides data
frontend -> ui_fw: uses frameworks

# Styling
k2g.style: {
  fill: "#fce4ec"
  stroke: "#c2185b"
}

kicad_ipc.style: {
  fill: "#fff3e0"
  stroke: "#e65100"
}

async_rt.style: {
  fill: "#e1f5ff"
  stroke: "#01579b"
}

serialization.style: {
  fill: "#e1f5ff"
  stroke: "#01579b"
}

validation.style: {
  fill: "#e1f5ff"
  stroke: "#01579b"
}

ui_fw.style: {
  fill: "#e8f5e9"
  stroke: "#1b5e20"
}

scripting.style: {
  fill: "#f3e5f5"
  stroke: "#4a148c"
}

tools.style: {
  fill: "#f3e5f5"
  stroke: "#4a148c"
}

k2g_modules.style: {
  fill: "#fce4ec"
  stroke: "#880e4f"
}

frontend.style: {
  fill: "#e8f5e9"
  stroke: "#1b5e20"
}

style: {
  stroke-width: 2
  font-size: 12
}
